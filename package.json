{
  "name": "@umituz/web-cloudflare",
  "version": "1.4.24",
  "description": "Comprehensive Cloudflare Workers & Pages integration with config-based patterns, middleware, router, workflows, and AI (Patch-only versioning: only z in x.y.z increments)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./workers": "./src/domains/workers/index.ts",
    "./kv": "./src/domains/kv/index.ts",
    "./r2": "./src/domains/r2/index.ts",
    "./d1": "./src/domains/d1/index.ts",
    "./images": "./src/domains/images/index.ts",
    "./analytics": "./src/domains/analytics/index.ts",
    "./workflows": "./src/domains/workflows/index.ts",
    "./ai-gateway": "./src/domains/ai-gateway/index.ts",
    "./workers-ai": "./src/domains/ai-gateway/index.ts",
    "./wrangler": "./src/domains/wrangler/index.ts",
    "./pages": "./src/domains/pages/index.ts",
    "./middleware": "./src/domains/middleware/index.ts",
    "./router": "./src/infrastructure/router/index.ts",
    "./utils": "./src/infrastructure/utils/helpers.ts",
    "./helpers": "./src/infrastructure/utils/helpers.ts",
    "./config": "./src/config/patterns.ts",
    "./patterns": "./src/config/patterns.ts",
    "./types": "./src/config/types.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "version:patch": "npm version patch -m 'chore: release v%s'",
    "version:minor": "npm version minor -m 'chore: release v%s'",
    "version:major": "npm version major -m 'chore: release v%s'"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "wrangler",
    "wrangler-cli",
    "edge",
    "kv",
    "r2",
    "d1",
    "cloudflare-images",
    "analytics",
    "workflows",
    "ai-gateway",
    "workers-ai",
    "pages",
    "cloudflare-pages",
    "static-site",
    "deployment",
    "router",
    "middleware",
    "config-patterns",
    "web",
    "edge-computing",
    "idempotent",
    "retryable",
    "serverless",
    "cdn",
    "caching",
    "rate-limiting",
    "cors",
    "security",
    "compression",
    "image-optimization",
    "typescript",
    "config-based"
  ],
  "author": "umituz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/umituz/web-cloudflare"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^9.32.0",
    "@types/node": "~22.13.10",
    "eslint": "^9.32.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.38.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
}
